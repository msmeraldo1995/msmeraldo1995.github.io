# Hugo build output
/public/
/resources/_gen/
.hugo_build.lock

# Node
node_modules/

# Generated by Docsy's postinstall (empty placeholder for Hugo module
# resolution when NOT using Go modules). Regenerated by `npm install` in
# themes/docsy. Safe to ignore — do not commit, do not delete manually.
/themes/github.com/

# Hugo's local module cache (if you ever switch to Hugo Modules)
/.hugo_cache/

# Local dev server logs (if you ever redirect hugo server output)
/srv.out
/srv.err

# OS / editor cruft
.DS_Store
Thumbs.db
